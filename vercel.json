{
  "buildCommand": "npm run build --workspace=frontend-web",
  "outputDirectory": "frontend-web/dist",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://backend-production-3620.up.railway.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
